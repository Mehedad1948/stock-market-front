    "/api/auth/logout": {
      "post": {
        "operationId": "logoutCurrentSession",
        "summary": "Revoke the current bearer session.",
        "tags": [
          "auth"
        ],
        "responses": {
          "200": {
            "description": "Revoke the current bearer session.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/LogoutResponse"
                }
              }
            }
          },
          "401": {
            "description": "Error 401",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "security": [
          {
            "bearerAuth": []
          }
        ]
      }
    },
    "/api/auth/subscription/trial": {
      "post": {
        "operationId": "activateTrialSubscription",
        "summary": "Activate the trial subscription for the authenticated user.",
        "tags": [
          "auth"
        ],
        "responses": {
          "201": {
            "description": "Activate the trial subscription for the authenticated user.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SubscriptionAccessResponse"
                }
              }
            }
          },
          "401": {
            "description": "Error 401",
