            "type": [
              "number",
              "null"
            ]
          },
          "notes": {
            "type": [
              "string",
              "null"
            ]
          }
        },
        "additionalProperties": false
      },
      "PortfolioResponse": {
        "type": "object",
        "required": [
          "status",
          "portfolio"
        ],
        "properties": {
          "status": {
            "type": "string",
            "enum": [
              "OK"
            ]
          },
          "portfolio": {
            "type": "object",
            "additionalProperties": true
          }
        }
      },
      "DeletePortfolioResponse": {
        "type": "object",
        "required": [
          "status",
          "removed"
        ],
        "properties": {
          "status": {
            "type": "string",
            "enum": [
              "OK"
            ]
          },
          "removed": {
            "type": "object",
            "additionalProperties": true
          }
        }
      }
