{
  "openapi": "3.1.0",
  "info": {
    "title": "Market Frontend Integration Contract (admin)",
    "version": "2026-06-26.1",
    "description": "Machine-readable contract for the admin endpoint scope."
  },
  "servers": [
    {
      "url": "http://localhost:3000",
      "description": "Local development"
    }
  ],
  "paths": {
    "/api/admin/discount-codes": {
      "post": {
        "operationId": "createDiscountCode",
        "summary": "Create a discount code for internal/admin workflows.",
        "tags": [
          "admin"
        ],
        "responses": {
          "201": {
            "description": "Create a discount code for internal/admin workflows.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DiscountCodeResponse"
                }
              }
            }
          },
          "400": {
            "description": "Error 400",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Error 401",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "security": [
          {
            "internalApiToken": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateDiscountCodeRequest"
              }
            }
          }
        }
      }
    },
    "/api/admin/discount-codes/apply": {
      "post": {
        "operationId": "applyDiscountCode",
        "summary": "Redeem a discount code for a plan checkout flow through the internal route.",
        "tags": [
          "admin"
        ],
        "responses": {
          "200": {
            "description": "Redeem a discount code for a plan checkout flow through the internal route.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DiscountPreviewResponse"
                }
              }
            }
          },
          "400": {
            "description": "Error 400",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Error 401",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "Error 404",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "409": {
            "description": "Error 409",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "security": [
          {
            "internalApiToken": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/DiscountCodeCheckoutRequest"
              }
            }
          }
        }
      }
    },
    "/api/admin/discount-codes/{id}/status": {
      "post": {
        "operationId": "updateDiscountCodeStatus",
        "summary": "Update a discount code status for internal/admin workflows.",
        "tags": [
          "admin"
        ],
        "responses": {
          "200": {
            "description": "Update a discount code status for internal/admin workflows.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DiscountCodeResponse"
                }
              }
            }
          },
          "400": {
            "description": "Error 400",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Error 401",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "Error 404",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "security": [
          {
            "internalApiToken": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateDiscountCodeStatusRequest"
              }
            }
          }
        },
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "minLength": 1
            }
          }
        ]
      }
    }
  },
  "components": {
    "schemas": {
      "ErrorResponse": {
        "type": "object",
        "required": [
          "status",
          "message"
        ],
        "properties": {
          "status": {
            "type": "string",
            "enum": [
              "ERROR"
            ]
          },
          "message": {
            "type": "string"
          },
          "englishMessage": {
            "type": "string"
          },
          "issues": {
            "type": "object",
            "additionalProperties": true
          },
          "preview": {
            "type": "object",
            "additionalProperties": true
          },
          "limit": {
            "type": "integer"
          },
          "accessLevel": {
            "type": "string"
          }
        },
        "additionalProperties": true
      },
      "CreateDiscountCodeRequest": {
        "type": "object",
        "required": [
          "code",
          "name",
          "valueType",
          "value"
        ],
        "properties": {
          "code": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "valueType": {
            "type": "string"
          },
          "value": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "number"
              }
            ]
          }
        },
        "additionalProperties": true
      },
      "DiscountCodeCheckoutRequest": {
        "type": "object",
        "required": [
          "code",
          "planCode"
        ],
        "properties": {
          "code": {
            "type": "string"
          },
          "planCode": {
            "type": "string"
          }
        },
        "additionalProperties": false
      },
      "UpdateDiscountCodeStatusRequest": {
        "type": "object",
        "required": [
          "status"
        ],
        "properties": {
          "status": {
            "type": "string"
          }
        },
        "additionalProperties": false
      },
      "DiscountCodeResponse": {
        "type": "object",
        "required": [
          "status",
          "discountCode"
        ],
        "properties": {
          "status": {
            "type": "string",
            "enum": [
              "OK"
            ]
          },
          "discountCode": {
            "type": "object",
            "additionalProperties": true
          }
        }
      },
      "DiscountPreviewResponse": {
        "type": "object",
        "required": [
          "status",
          "preview"
        ],
        "properties": {
          "status": {
            "type": "string",
            "enum": [
              "OK"
            ]
          },
          "preview": {
            "type": "object",
            "additionalProperties": true
          }
        }
      }
    },
    "securitySchemes": {
      "internalApiToken": {
        "type": "apiKey",
        "in": "header",
        "name": "x-internal-api-token"
      }
    }
  }
}
